{
  "name": "llmroute-assistant",
  "displayName": "LLM Router Assistant",
  "description": "A local, agentic AI coding assistant powered by your llmroute gateway (Ollama). Chats, reads your code, proposes edits, and runs commands with your approval.",
  "version": "0.1.0",
  "publisher": "shishodiaabhilash",
  "license": "MIT",
  "repository": { "type": "git", "url": "https://github.com/shishodiaabhilash/llm-cost-aware-routing" },
  "engines": { "vscode": "^1.85.0" },
  "categories": ["AI", "Chat", "Machine Learning", "Programming Languages"],
  "activationEvents": [],
  "main": "./extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        { "id": "llmrouter", "title": "LLM Router", "icon": "media/icon.svg" }
      ]
    },
    "views": {
      "llmrouter": [
        { "id": "llmrouter.chat", "name": "Assistant", "type": "webview" }
      ]
    },
    "commands": [
      { "command": "llmrouter.focusChat", "title": "LLM Router: Open Assistant" },
      { "command": "llmrouter.newChat", "title": "LLM Router: New Chat", "icon": "$(add)" },
      { "command": "llmrouter.showStats", "title": "LLM Router: Show Routing Stats" },
      { "command": "llmrouter.explain", "title": "LLM Router: Explain Selection" },
      { "command": "llmrouter.fix", "title": "LLM Router: Fix Selection" },
      { "command": "llmrouter.doc", "title": "LLM Router: Document Selection" },
      { "command": "llmrouter.tests", "title": "LLM Router: Generate Tests" },
      { "command": "llmrouter.toggleCompletions", "title": "LLM Router: Toggle Inline Completions" }
    ],
    "menus": {
      "view/title": [
        { "command": "llmrouter.newChat", "when": "view == llmrouter.chat", "group": "navigation" }
      ],
      "editor/context": [
        { "command": "llmrouter.explain", "when": "editorHasSelection", "group": "llmrouter@1" },
        { "command": "llmrouter.fix", "when": "editorHasSelection", "group": "llmrouter@2" },
        { "command": "llmrouter.doc", "when": "editorHasSelection", "group": "llmrouter@3" },
        { "command": "llmrouter.tests", "when": "editorHasSelection", "group": "llmrouter@4" }
      ]
    },
    "configuration": {
      "title": "LLM Router Assistant",
      "properties": {
        "llmrouter.gatewayUrl": {
          "type": "string",
          "default": "http://localhost:11435",
          "description": "Base URL of the running llmroute gateway."
        },
        "llmrouter.model": {
          "type": "string",
          "default": "auto",
          "description": "Model to request. 'auto' lets the router decide the tier."
        },
        "llmrouter.agentModel": {
          "type": "string",
          "default": "",
          "description": "Model used for the agent loop. Empty = use the gateway's large tier (recommended for reliable tool use). 'auto' = let the router decide (cheaper, weaker at tool following). Or a specific model tag."
        },
        "llmrouter.completionModel": {
          "type": "string",
          "default": "",
          "description": "Model used for inline (ghost-text) completions. Empty = use the gateway's small/local tier (fast). Or a specific model tag (a code model like qwen2.5-coder is recommended)."
        },
        "llmrouter.enableCompletions": {
          "type": "boolean",
          "default": true,
          "description": "Enable inline (ghost-text) autocomplete."
        },
        "llmrouter.maxSteps": {
          "type": "number",
          "default": 6,
          "description": "Maximum agent tool steps per user turn."
        },
        "llmrouter.autoApproveReadTools": {
          "type": "boolean",
          "default": true,
          "description": "Auto-run read-only tools (read_file, list_dir). Edits and commands always ask."
        }
      }
    }
  }
}
